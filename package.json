{
  "name": "landeon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:local:start": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data -l /tmp/landeon-postgres.log start",
    "db:local:stop": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data stop",
    "db:local:status": "/usr/lib/postgresql/16/bin/pg_ctl -D .postgres-data status",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:restart": "sh -c 'pm2 stop landeon-web >/dev/null 2>&1 || true; npm run build && (pm2 restart landeon-web --update-env || pm2 start ecosystem.config.cjs --only landeon-web --update-env) && (pm2 restart landeon-postgres --update-env || pm2 start ecosystem.config.cjs --only landeon-postgres --update-env)'",
    "pm2:stop": "pm2 stop landeon-web landeon-postgres",
    "pm2:logs": "pm2 logs landeon-web landeon-postgres"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.16.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.395.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.4.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.39",
    "prisma": "^5.16.1",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
