generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                 String   @id @default(cuid())
  name               String
  prompt             String?  @db.Text
  businessName       String?
  businessDescription String? @db.Text
  targetAudience     String?
  goal               String?
  tone               String?
  visualStyle        String?
  primaryAccent      String?
  language           String   @default("English")
  pageJson           Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  aiLogs     AIGenerationLog[]
  exports    ExportRecord[]

  @@map("projects")
}

model AIGenerationLog {
  id            String   @id @default(cuid())
  projectId     String
  actionType    String   // "generate_page" | "rewrite_section" | "regenerate_section" | "suggest_cta" | "make_shorter" | "make_premium" | "make_formal"
  inputPayload  Json
  outputPayload Json
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("ai_generation_logs")
}

model ExportRecord {
  id         String   @id @default(cuid())
  projectId  String
  exportType String   @default("zip") // "zip" | "html"
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("export_records")
}
